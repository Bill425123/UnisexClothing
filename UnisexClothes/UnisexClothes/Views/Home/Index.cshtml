                    <div class="card-body text-center p-4">
                        <div class="mb-3" style="font-size: 3rem; color: #2196F3;">
                            <i class="fas fa-sync-alt"></i>
                        </div>
                        <h5 class="fw-bold mb-3" style="color: #1a1a1a;">Đổi Trả Dễ Dàng</h5>
                        <p class="text-muted mb-3" style="font-size: 0.95rem;">Đổi trả miễn phí trong 7 ngày nếu không vừa ý</p>
                        <div class="mt-3">
                            <span class="badge bg-primary" style="padding: 8px 16px; border-radius: 20px;">
                                <i class="fas fa-shield-alt me-1"></i>Hoàn tiền 100%
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 4: Customer Reviews -->
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-lg" style="background: #ffffff; border-radius: 15px; overflow: hidden; transition: transform 0.3s ease;" onmouseover="this.style.transform='translateY(-10px)'" onmouseout="this.style.transform='translateY(0)'">
                    <div class="card-body text-center p-4">
                        <div class="mb-3" style="font-size: 3rem; color: #FF9800;">
                            <i class="fas fa-star"></i>
                        </div>
                        <h5 class="fw-bold mb-3" style="color: #1a1a1a;">Đánh Giá 5 Sao</h5>
                        <p class="text-muted mb-3" style="font-size: 0.95rem;">Hơn 10,000+ khách hàng hài lòng trên toàn quốc</p>
                        <div class="mt-3">
                            <div class="text-warning mb-2" style="font-size: 1.2rem;">
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                            </div>
                            <small class="text-muted">4.9/5.0 điểm</small>
                        </div>
                    </div>
                </div>
            </div>
