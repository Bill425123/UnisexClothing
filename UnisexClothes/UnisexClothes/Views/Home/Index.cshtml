                    </div>

                    <!-- Brand 3: Fashion Brands Grid -->
                    <div class="col-12">
                        <div class="brand-card-hover position-relative overflow-hidden" style="border-radius: 15px; height: 240px; cursor: pointer;">
                            <img src="~/images/HìnhthemcheckoutUniSex/top-10-thuong-hieu-thoi-trang-nu-noi-tieng-nhat-tai-viet-nam-202103280407039594.png" class="brand-image w-100 h-100" style="object-fit: cover; transition: transform 0.5s ease;" alt="Fashion Brands">
                            <div class="brand-overlay position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 50%); transition: background 0.3s ease;"></div>
                            <div class="position-absolute bottom-0 start-0 end-0 p-3 text-center">
                                <small class="text-warning d-block mb-1"><i class="fas fa-fire me-1"></i>TRENDING</small>
                                <h6 class="text-white fw-bold mb-1">Top Thương Hiệu Thời Trang Nữ</h6>
                                <p class="text-white-50 small mb-0 brand-description" style="opacity: 0; transition: opacity 0.3s ease;">
                                    Chanel, LV, Hermès, Prada... Bộ sưu tập đẳng cấp dành cho phái đẹp
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Brand Grid -->
        <div class="row g-4 mt-3">
            <div class="col-md-6">
