@section Scripts {
    <script>
        let loadedProducts = 0;
        const productsPerPage = 4;

        // Load featured products from database
        document.addEventListener('DOMContentLoaded', function() {
            loadFeaturedProducts();
            
            // Make category cards clickable
            document.querySelectorAll('.category-card').forEach((card) => {
                const categoryUrl = card.dataset.categoryUrl;
                if (!categoryUrl) return;
                
                card.style.cursor = 'pointer';
                card.addEventListener('click', function() {
                    window.location.href = categoryUrl;
                });
            });
        });

        function loadFeaturedProducts() {
            fetch(`/Home/GetFeaturedProducts?take=${productsPerPage}&skip=0`)
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        renderProducts(result.data);
                        loadedProducts = result.data.length;
                        
                        // Show "Load More" button if there are more products
                        if (result.data.length === productsPerPage) {
                            document.getElementById('loadMoreBtn').style.display = 'inline-block';
                        }
                    } else {
                        document.getElementById('featuredProductsContainer').innerHTML = 
                            '<div class="col-12 text-center text-danger">Không thể tải sản phẩm: ' + result.message + '</div>';
                    }
                })
                .catch(error => {
                    console.error('Error loading products:', error);
                    document.getElementById('featuredProductsContainer').innerHTML = 
                        '<div class="col-12 text-center text-danger">Lỗi tải sản phẩm!</div>';
                });
        }

        function loadMoreProducts() {
            const btn = document.getElementById('loadMoreBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang tải...';

            fetch(`/Home/GetFeaturedProducts?take=${productsPerPage}&skip=${loadedProducts}`)
                .then(response => response.json())
                .then(result => {
                    if (result.success && result.data.length > 0) {
                        appendProducts(result.data);
                        loadedProducts += result.data.length;
                        
                        // Hide button if no more products
                        if (result.data.length < productsPerPage) {
                            btn.style.display = 'none';
                        } else {
                            btn.disabled = false;
                            btn.innerHTML = '<i class="fas fa-plus-circle me-2"></i>Xem thêm sản phẩm';
                        }
                    } else {
                        btn.style.display = 'none';
                    }
                })
                .catch(error => {
                    console.error('Error loading more products:', error);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-plus-circle me-2"></i>Xem thêm sản phẩm';
                    alert('Không thể tải thêm sản phẩm!');
                });
        }

        function renderProducts(products) {
            const container = document.getElementById('featuredProductsContainer');
            container.innerHTML = '';

            if (!products || products.length === 0) {
                container.innerHTML = '<div class="col-12 text-center text-muted">Chưa có sản phẩm nào</div>';
                return;
            }

            products.forEach(product => {
                container.innerHTML += createProductCard(product);
            });
        }

        function appendProducts(products) {
            const container = document.getElementById('featuredProductsContainer');
            
            if (!products || products.length === 0) {
                return;
            }

            products.forEach(product => {
                container.innerHTML += createProductCard(product);
            });
        }

        function createProductCard(product) {
            const categoryMap = { 'Áo': 'ao', 'Quần': 'quan', 'Phụ kiện': 'phukien' };
            const categoryClass = categoryMap[product.category] || 'ao';
            
            const discountBadge = product.discount > 0 
                ? `<span class="badge bg-danger position-absolute top-0 start-0 m-2">-${product.discount}%</span>`
                : '';
            
            const originalPrice = product.discount > 0 
                ? `<span class="text-muted text-decoration-line-through ms-2" style="font-size: 0.9rem;">${formatPrice(product.price)}₫</span>`
                : '';
            
            const stars = generateStars(product.rating);
            
            return `
                <div class="col-12 col-sm-6 col-md-3 col-lg-3 mb-4" data-category="${categoryClass}">
                    <div class="card product-card position-relative h-100 d-flex flex-column">
                        ${discountBadge}
                        <a href="/Product/Detail/${product.id}" class="text-decoration-none d-block">
                            <img src="${product.image}" class="card-img-top product-img" alt="${product.name}" 
                                 onerror="this.src='/images/HinhSanPhamUnisex/default.jpg'">
                        </a>
                        <div class="card-body d-flex flex-column">
                            <a href="/Product/Detail/${product.id}" class="text-decoration-none text-dark">
                                <h5 class="card-title product-title mb-2" style="min-height: 40px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">${product.name}</h5>
                            </a>
                            <div class="d-flex align-items-center mb-1">
                                <div class="text-warning" style="font-size: 0.85rem;">
                                    ${stars}
                                </div>
                                <small class="text-muted ms-1" style="font-size: 0.75rem;">(${product.rating})</small>
                            </div>
                            <p class="text-muted mb-2" style="font-size: 0.85rem;">${product.category}</p>
                            <p class="mb-2 mt-auto">
                                <span class="product-price text-danger fw-bold">${formatPrice(product.salePrice)}₫</span>
                                ${originalPrice}
                            </p>
                            <div class="d-flex gap-2 mt-auto">
                                <button class="btn btn-unistyle w-100" onclick="handleBuyNow(${product.id})">
                                    <i class="fas fa-bolt me-1"></i>Mua ngay
                                </button>
                                <button class="btn btn-outline-dark" onclick="handleAddToCart(${product.id})" title="Thêm vào giỏ">
                                    <i class="fas fa-shopping-cart"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        function formatPrice(price) {
            return new Intl.NumberFormat('vi-VN').format(Math.round(price));
        }

        function generateStars(rating) {
            const fullStars = Math.floor(rating);
            const hasHalfStar = rating % 1 >= 0.5;
            const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
            
            let starsHTML = '';
            for (let i = 0; i < fullStars; i++) {
                starsHTML += '<i class="fas fa-star"></i>';
            }
            if (hasHalfStar) {
                starsHTML += '<i class="fas fa-star-half-alt"></i>';
            }
            for (let i = 0; i < emptyStars; i++) {
                starsHTML += '<i class="far fa-star"></i>';
            }
            return starsHTML;
        }

        // Function buyNow và addToCart đã được định nghĩa trong site.js (window.buyNow, window.addToCart)
        // Không cần function local nữa - onclick gọi trực tiếp window.buyNow và window.addToCart
    </script>
}
