                <div class="p-4" style="background: rgba(255,255,255,0.1); border-radius: 15px; border: 1px solid rgba(255,255,255,0.2);">
                    <h2 class="fw-bold text-white mb-2" style="font-size: 2.5rem;">10K+</h2>
                    <p class="text-white-50 mb-0">Khách hàng</p>
                </div>
            </div>
            <div class="col-6 col-md-3 text-center">
                <div class="p-4" style="background: rgba(255,255,255,0.1); border-radius: 15px; border: 1px solid rgba(255,255,255,0.2);">
                    <h2 class="fw-bold text-white mb-2" style="font-size: 2.5rem;">500+</h2>
                    <p class="text-white-50 mb-0">Sản phẩm</p>
                </div>
            </div>
            <div class="col-6 col-md-3 text-center">
                <div class="p-4" style="background: rgba(255,255,255,0.1); border-radius: 15px; border: 1px solid rgba(255,255,255,0.2);">
                    <h2 class="fw-bold text-white mb-2" style="font-size: 2.5rem;">99%</h2>
                    <p class="text-white-50 mb-0">Hài lòng</p>
                </div>
            </div>
            <div class="col-6 col-md-3 text-center">
                <div class="p-4" style="background: rgba(255,255,255,0.1); border-radius: 15px; border: 1px solid rgba(255,255,255,0.2);">
                    <h2 class="fw-bold text-white mb-2" style="font-size: 2.5rem;">24/7</h2>
