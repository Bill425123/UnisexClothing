</section>

<!-- Featured Products Section -->
<section class="py-5 section-bg-light">
    <div class="container">
        <h2 class="section-title">Sản phẩm nổi bật</h2>
        <div class="row g-4" id="featuredProductsContainer">
            <!-- Products will be loaded from database here -->
            <div class="col-12 text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Đang tải...</span>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <button id="loadMoreBtn" class="btn btn-unistyle btn-lg" onclick="loadMoreProducts()" style="display: none;">
                <i class="fas fa-plus-circle me-2"></i>Xem thêm sản phẩm
            </button>
            <a asp-controller="Product" asp-action="Shop" class="btn btn-outline-dark btn-lg ms-2">Xem tất cả</a>
        </div>
    </div>
</section>

<!-- Brand Partners Section - Luxury Brands -->
<section class="py-5 section-bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold mb-2" style="font-size: 2rem;">THƯƠNG HIỆU NỔI TIẾNG</h2>
            <p class="text-muted mb-0">UniStyle hợp tác với các thương hiệu thời trang hàng đầu thế giới</p>
        </div>

        <div class="row g-4">
            <!-- Large featured brand showcase -->
            <div class="col-md-6">
                <div class="brand-card-hover position-relative overflow-hidden" style="border-radius: 20px; height: 100%; cursor: pointer;">
                    <img src="~/images/HìnhthemcheckoutUniSex/top-30-thuong-hieu-thoi-trang-noi-tieng-noi-nhat-the-gioi-7.webp" class="brand-image w-100 h-100" style="object-fit: cover; min-height: 500px; transition: transform 0.5s ease;" alt="Top Brands">
                    <div class="brand-overlay position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 50%); transition: background 0.3s ease;"></div>
