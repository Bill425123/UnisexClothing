                </div>
            </div>

            <!-- Grid of brand images -->
            <div class="col-md-6">
                <div class="row g-4">
                    <!-- Brand 1: Gucci -->
                    <div class="col-6">
                        <div class="brand-card-hover position-relative overflow-hidden" style="border-radius: 15px; height: 240px; background: #f8f9fa; cursor: pointer;">
                            <img src="~/images/HìnhthemcheckoutUniSex/gucci-585630.jpg" class="brand-image w-100 h-100" style="object-fit: contain; padding: 20px; transition: transform 0.5s ease;" alt="Gucci">
                            <div class="brand-overlay-full position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="background: rgba(0,0,0,0); transition: background 0.3s ease;">
                                <div class="text-center p-3" style="opacity: 0; transition: opacity 0.3s ease;">
