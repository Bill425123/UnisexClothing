@model IEnumerable<UnisexClothes.Models.Category>
@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    /* Hero Carousel Styles */
    .hero-carousel {
        border-radius: 0;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
    }

    .hero-carousel .carousel-item {
        height: 600px;
    }

    .hero-carousel .carousel-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
    }

    .hero-carousel .carousel-control-prev,
    .hero-carousel .carousel-control-next {
        width: 50px;
        height: 50px;
        top: 50%;
        transform: translateY(-50%);
        background-color: rgba(0, 0, 0, 0.5);
        border-radius: 50%;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .hero-carousel:hover .carousel-control-prev,
    .hero-carousel:hover .carousel-control-next {
        opacity: 1;
    }

    .hero-carousel .carousel-control-prev {
        left: 20px;
    }

    .hero-carousel .carousel-control-next {
        right: 20px;
    }

    .hero-carousel .carousel-indicators {
        bottom: 20px;
    }

    .hero-carousel .carousel-indicators button {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        margin: 0 5px;
        background-color: rgba(255, 255, 255, 0.5);
        border: 2px solid transparent;
        transition: all 0.3s ease;
    }

    .hero-carousel .carousel-indicators button.active {
        background-color: #fff;
        transform: scale(1.2);
    }

    @@media (max-width: 768px) {
        .hero-carousel .carousel-item {
            height: 400px;
        }
    }

    /* Brand Image Hover Effects */
    .brand-card-hover:hover .brand-image {
        transform: scale(1.1);
    }

    .brand-card-hover:hover .brand-overlay {
        background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.3) 100%) !important;
    }

    .brand-card-hover:hover .brand-overlay-full {
        background: rgba(0,0,0,0.85) !important;
    }

    .brand-card-hover:hover .brand-overlay-full > div {
        opacity: 1 !important;
    }

    .brand-card-hover:hover .brand-description {
        opacity: 1 !important;
    }

    .brand-card-hover:hover .brand-hover-text {
        opacity: 1 !important;
    }

    .brand-card-hover {
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .brand-card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
</style>

<!-- Hero Section -->
<section class="hero-banner-section">
    <div class="container">
        <div class="row align-items-center">
            <!-- Left side - Carousel Slider -->
            <div class="col-lg-8 mb-4 mb-lg-0 p-0">
                <div id="heroCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel">
                    <!-- Indicators -->
                    <div class="carousel-indicators">
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3" aria-label="Slide 4"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="4" aria-label="Slide 5"></button>
                    </div>
                    
                    <!-- Slides -->
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <img src="~/images/HinhchuyendongUnisex/2081182.png" class="d-block w-100" alt="Fashion Style 1">
                        </div>
                        <div class="carousel-item">
                            <img src="~/images/HinhchuyendongUnisex/318889.jpg" class="d-block w-100" alt="Fashion Style 2">
                        </div>
                        <div class="carousel-item">
                            <img src="~/images/HinhchuyendongUnisex/anh-bia-thoi-trang (2).jpg" class="d-block w-100" alt="Fashion Style 3">
                        </div>
                        <div class="carousel-item">
                            <img src="~/images/HinhchuyendongUnisex/items-khien-ban-tro-nen-thoi-trang-hon-scaled.jpg" class="d-block w-100" alt="Fashion Style 4">
                        </div>
                        <div class="carousel-item">
                            <img src="~/images/HinhchuyendongUnisex/maxresdefault.jpg" class="d-block w-100" alt="Fashion Style 5">
                        </div>
                    </div>
                    
                    <!-- Controls -->
                    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>
            <!-- Right side - Text -->
            <div class="col-lg-4 text-center text-lg-start ps-lg-5 py-5">
                <h1 class="display-1 fw-bold mb-3" style="letter-spacing: 4px; color: #1a1a1a;">UNISTYLE</h1>
                <p class="lead mb-4" style="font-size: 1.2rem; color: #666;">Thời trang unisex hiện đại - Tối giản - Phong cách</p>
                
                <div class="mb-4" style="color: #555;">
                    <p style="font-size: 1rem; line-height: 1.8; margin-bottom: 20px;">
                        UniStyle là thương hiệu thời trang unisex hàng đầu tại Việt Nam, chuyên cung cấp các sản phẩm thời trang chất lượng cao với thiết kế tối giản và hiện đại.
                    </p>
                    
                    <div class="mb-3">
                        <div class="d-flex align-items-start mb-2">
                            <i class="fas fa-check-circle text-success me-3" style="font-size: 1.2rem; margin-top: 4px;"></i>
                            <span>Chất liệu cao cấp 100%</span>
                        </div>
                        <div class="d-flex align-items-start mb-2">
                            <i class="fas fa-check-circle text-success me-3" style="font-size: 1.2rem; margin-top: 4px;"></i>
                            <span>Thiết kế độc đáo, phù hợp mọi phong cách</span>
                        </div>
                        <div class="d-flex align-items-start mb-2">
                            <i class="fas fa-check-circle text-success me-3" style="font-size: 1.2rem; margin-top: 4px;"></i>
                            <span>Đổi trả miễn phí trong 7 ngày</span>
                        </div>
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-3" style="font-size: 1.2rem; margin-top: 4px;"></i>
                            <span>Giao hàng toàn quốc</span>
                        </div>
                    </div>
                </div>
                
                <div class="d-flex gap-3 flex-wrap justify-content-center justify-content-lg-start">
                    <a asp-controller="Product" asp-action="Shop" class="btn btn-dark btn-lg px-4 py-3" style="width: 280px; flex-shrink: 0;">
                        <i class="fas fa-shopping-bag me-2"></i>Khám phá ngay
                    </a>
                    <a asp-controller="SpinWheel" asp-action="Index" class="btn btn-lg px-4 py-3" 
                       style="background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); color: white; border: none; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4); width: 280px; flex-shrink: 0;">
                        <i class="fas fa-gift me-2"></i>Vòng quay may mắn
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="py-5 section-bg-white">
    <div class="container">
        <h2 class="section-title">Danh mục</h2>
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var category in Model)
                {
                    var imageUrl = string.IsNullOrWhiteSpace(category.CategoryImage)
                        ? "/images/HinhSanPhamUnisex/default.jpg"
                        : category.CategoryImage;
                    var categoryUrl = Url.Action("Shop", "Product", new { category = $"cat-{category.CategoryId}" });
                    <div class="col-md-4 col-lg-3">
                        <div class="category-card p-0" data-category="@category.CategoryId" data-category-url="@categoryUrl" style="cursor: pointer;">
                            <div class="position-relative">
                                <img src="@imageUrl" alt="@category.CategoryName" class="img-fluid category-img" onerror="this.src='/images/HinhSanPhamUnisex/default.jpg'">
                                <div class="position-absolute bottom-0 start-0 end-0 bg-white p-3">
                                    <h5 class="fw-bold mb-1 text-center">@category.CategoryName</h5>
                                    @if (!string.IsNullOrWhiteSpace(category.Description))
                                    {
                                        <p class="text-muted small mb-0 text-center">@category.Description</p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted">
                    Chưa có danh mục nào được kích hoạt.
                </div>
            }
        </div>
    </div>
</section>

