@{
    ViewData["Title"] = "Kho Voucher";
}

<!-- My Vouchers Page -->
<section class="py-5" style="background: linear-gradient(135deg, #e9ecef 0%, #f8f9fa 100%); min-height: 100vh;">
    <div class="container">
        <!-- Header -->
        <div class="text-center text-dark mb-5">
            <h1 class="display-4 fw-bold mb-3">
                <i class="fas fa-wallet me-3"></i>KHO VOUCHER CỦA BẠN
            </h1>
            <p class="lead mb-4">Tất cả voucher bạn đã lưu từ vòng quay may mắn</p>
        </div>

        <!-- Vouchers Grid -->
        <div class="row g-4" id="vouchersContainer">
            <!-- Loading -->
            <div class="col-12 text-center" id="loadingSpinner">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3 text-dark">Đang tải voucher...</p>
            </div>
        </div>

        <!-- Empty State -->
        <div id="emptyState" class="text-center py-5" style="display: none;">
            <i class="fas fa-inbox text-muted" style="font-size: 5rem;"></i>
            <h3 class="mt-4 text-muted">Chưa có voucher nào</h3>
            <p class="text-muted">Hãy quay vòng may mắn để nhận voucher!</p>
            <a href="@Url.Action("Index", "SpinWheel")" class="btn btn-primary btn-lg mt-3">
                <i class="fas fa-gift me-2"></i>Đi quay ngay
            </a>
        </div>
    </div>
</section>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        loadMyVouchers();
    });

    async function loadMyVouchers() {
        try {
            const response = await fetch('/SpinWheel/GetMyVouchers');
            const result = await response.json();

            document.getElementById('loadingSpinner').style.display = 'none';

            if (result.success && result.vouchers && result.vouchers.length > 0) {
                renderVouchers(result.vouchers);
            } else {
                document.getElementById('emptyState').style.display = 'block';
            }
        } catch (error) {
            document.getElementById('loadingSpinner').style.display = 'none';
            document.getElementById('emptyState').style.display = 'block';
            console.error('Error loading vouchers:', error);
        }
    }

    function renderVouchers(vouchers) {
        const container = document.getElementById('vouchersContainer');
        container.innerHTML = '';

        vouchers.forEach((voucher, index) => {
            const expiryDate = voucher.expiryDate || voucher.ExpiryDate ? new Date(voucher.expiryDate || voucher.ExpiryDate) : null;
            const isExpired = expiryDate && expiryDate < new Date();
            const daysLeft = expiryDate ? Math.ceil((expiryDate - new Date()) / (1000 * 60 * 60 * 24)) : 0;

            // Handle both lowercase and uppercase property names
            const voucherCode = voucher.code || voucher.Code || 'N/A';
            const voucherName = voucher.name || voucher.Name || 'Voucher';
            const voucherValue = voucher.value || voucher.Value || 0;
            const voucherType = voucher.type || voucher.Type || 'amount';

            const card = `
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 ${isExpired ? 'opacity-50' : ''}" 
                         style="border-radius: 15px; background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);">
                        <div class="card-body p-4 text-white">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="card-title fw-bold mb-1">${voucherName}</h5>
                                    <span class="badge ${isExpired ? 'bg-danger' : 'bg-light text-dark'}">
                                        ${isExpired ? 'Hết hạn' : daysLeft + ' ngày còn lại'}
                                    </span>
                                </div>
                                <i class="fas fa-ticket-alt fa-2x"></i>
                            </div>
                            
                            <div class="mb-3">
                                <div class="bg-white bg-opacity-25 rounded p-3 text-center">
                                    <small class="d-block mb-1">Mã voucher</small>
                                    <code class="text-white fs-4 fw-bold">${voucherCode}</code>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <small class="d-block">Giá trị</small>
                                    <strong class="fs-4">${formatValue({value: voucherValue, type: voucherType})}</strong>
                                </div>
                                <div class="text-end">
                                    <small class="d-block">Loại</small>
                                    <strong>${getTypeText(voucherType)}</strong>
                                </div>
                            </div>

                            ${!isExpired ? `
                                <div class="d-grid gap-2">
                                    <button class="btn btn-warning fw-bold" onclick="applyVoucherNow('${voucherCode}')">
                                        <i class="fas fa-shopping-cart me-2"></i>Áp dụng voucher ngay
                                    </button>
                                    <button class="btn btn-light" onclick="copyCode('${voucherCode}')">
                                        <i class="fas fa-copy me-2"></i>Sao chép mã
                                    </button>
                                </div>
                            ` : `
                                <button class="btn btn-secondary w-100" disabled>
                                    <i class="fas fa-ban me-2"></i>Đã hết hạn
                                </button>
                            `}
                        </div>
                    </div>
                </div>
            `;

            container.innerHTML += card;
        });
    }

    function formatValue(voucher) {
        if (voucher.type === 'amount') {
            return new Intl.NumberFormat('vi-VN').format(voucher.value) + '₫';
        } else if (voucher.type === 'percent') {
            return voucher.value + '%';
        } else if (voucher.type === 'freeship') {
            return 'Miễn phí ship';
        }
        return '-';
    }

    function getTypeText(type) {
        switch(type) {
            case 'amount': return 'Giảm tiền';
            case 'percent': return 'Giảm %';
            case 'freeship': return 'Free ship';
            default: return 'Khác';
        }
    }

    function copyCode(code) {
        navigator.clipboard.writeText(code).then(() => {
            alert('✓ Đã sao chép mã: ' + code);
        }).catch(err => {
            // Fallback for older browsers
            const textarea = document.createElement('textarea');
            textarea.value = code;
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            document.body.removeChild(textarea);
            alert('✓ Đã sao chép mã: ' + code);
        });
    }

    // Apply voucher and redirect to Cart
    async function applyVoucherNow(voucherCode) {
        try {
            // Validate voucher first
            const response = await fetch('/Cart/ValidateVoucher?code=' + voucherCode);
            const result = await response.json();

            if (result.success) {
                // Save voucher to localStorage
                localStorage.setItem('appliedVoucher', JSON.stringify(result.voucher));
                
                // Always redirect to Cart - Cart will auto-apply the voucher
                alert('✓ Voucher đã được lưu!\n\nĐang chuyển đến giỏ hàng...');
                window.location.href = '/Cart';
            } else {
                alert('✗ ' + result.message);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('✗ Lỗi khi áp dụng voucher!');
        }
    }
</script>
}
