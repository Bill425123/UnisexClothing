                    <div class="card-body">
                        <h5 class="card-title product-title">Mũ Snapback UniStyle</h5>
                        <p class="product-price">349.000 ₫</p>
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="7" class="btn btn-outline-dark w-100">Xem chi tiết</a>
