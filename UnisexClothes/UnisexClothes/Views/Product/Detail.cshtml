@section Scripts {
    <script>
        // Get product ID from URL
        function getProductId() {
            // Try to get from URL path first (e.g., /Product/Detail/1)
            const pathParts = window.location.pathname.split('/');
            const idFromPath = parseInt(pathParts[pathParts.length - 1]);
            if (!isNaN(idFromPath) && idFromPath > 0) {
                return idFromPath;
            }
            // If not found, try query string
            const urlParams = new URLSearchParams(window.location.search);
            const idFromQuery = parseInt(urlParams.get('id'));
            if (!isNaN(idFromQuery) && idFromQuery > 0) {
                return idFromQuery;
            }
            // Default to 1
            return 1;
        }

        // Format price
        function formatPrice(price) {
            return new Intl.NumberFormat('vi-VN').format(Math.round(price));
        }

        // Parse description into features
        function parseDescription(description) {
            if (!description) return [];
            // Split by common delimiters
            const lines = description.split(/[\.\n]/).filter(line => line.trim().length > 0);
            return lines.slice(0, 4); // Take first 4 features
        }

        // Default colors based on category
        function getDefaultColors(categoryId) {
            const colorMap = {
                1: ["#000000", "#ffffff", "#808080", "#4169E1"], // Áo
                2: ["#000000", "#8B4513", "#808080", "#2F4F4F"], // Quần
                3: ["#8B4513", "#000000", "#2F4F4F", "#ffffff"]  // Phụ kiện
            };
            return colorMap[categoryId] || ["#000000", "#ffffff", "#808080", "#4169E1"];
        }

        // Load product data from API
        function loadProduct() {
            const productId = getProductId();
            const container = document.querySelector('.container');
            
            // Show loading
            const loadingHTML = '<div class="col-12 text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Đang tải...</span></div></div>';
            
            fetch(`/Product/GetProductDetail?id=${productId}`)
                .then(response => response.json())
                .then(result => {
                    if (result.success && result.data) {
                        const product = result.data;
                        renderProduct(product);
                    } else {
                        document.getElementById('productTitle').textContent = 'Không tìm thấy sản phẩm';
                        document.getElementById('productImage').src = '/images/HinhSanPhamUnisex/default.jpg';
                    }
                })
                .catch(error => {
                    console.error('Error loading product:', error);
                    document.getElementById('productTitle').textContent = 'Lỗi tải sản phẩm';
                    document.getElementById('productImage').src = '/images/HinhSanPhamUnisex/default.jpg';
                });
        }

        // Render product data
        function renderProduct(product) {
            // Update image
            document.getElementById('productImage').src = product.image;
            document.getElementById('productImage').onerror = function() {
                this.src = '/images/HinhSanPhamUnisex/default.jpg';
            };

            // Update title and code
            document.getElementById('productTitle').textContent = product.name;
            document.getElementById('productCode').textContent = `Mã sản phẩm: ${product.id.toString().padStart(6, '0')}`;

            // Update price
            const currentPriceText = `${formatPrice(product.salePrice)} ₫`;
            const originalPriceText = product.discount > 0 ? `${formatPrice(product.price)} ₫` : '';
            
            document.getElementById('currentPrice').textContent = currentPriceText;
            if (product.discount > 0) {
                document.getElementById('originalPrice').textContent = originalPriceText;
                document.getElementById('originalPrice').style.display = '';
            } else {
                document.getElementById('originalPrice').style.display = 'none';
            }

            // Update description
            const description = product.description || 'Sản phẩm chất lượng cao từ UniStyle.';
            document.getElementById('descriptionText').textContent = description;
            
            const descriptionList = document.getElementById('descriptionList');
            descriptionList.innerHTML = '';
            const features = parseDescription(description);
            if (features.length === 0) {
                features.push('Chất liệu cao cấp', 'Thiết kế hiện đại', 'Phù hợp mọi lứa tuổi', 'Bền đẹp');
            }
            features.forEach(feature => {
                const li = document.createElement('li');
                li.textContent = feature.trim();
                if (li.textContent) {
                    descriptionList.appendChild(li);
                }
            });

            // Update colors
            const colorOptions = document.getElementById('colorOptions');
            colorOptions.innerHTML = '';
            const colors = getDefaultColors(product.categoryId);
            colors.forEach((color, index) => {
                const span = document.createElement('span');
                span.className = 'color-option' + (index === 0 ? ' selected' : '');
                span.style.backgroundColor = color;
                span.onclick = function() { selectColor(this); };
                colorOptions.appendChild(span);
            });

            // Update add to cart button
            document.getElementById('addToCartBtn').setAttribute('onclick', `handleAddToCart(${product.id}, parseInt(document.querySelector('.quantity-input').value))`);
        }

        function validateQuantity(input) {
            let value = parseInt(input.value);
            
            // Chặn số âm, 0 và số không hợp lệ
            if (isNaN(value) || value < 1) {
                input.value = 1;
            } else if (value > 999) {
                input.value = 999;
            } else {
                input.value = value;
            }
        }

        function decreaseQuantity() {
            const input = document.querySelector('.quantity-input');
            let value = parseInt(input.value) || 1;
            if (value > 1) {
                input.value = value - 1;
            }
        }

        function increaseQuantity() {
            const input = document.querySelector('.quantity-input');
            let value = parseInt(input.value) || 1;
            if (value < 999) {
                input.value = value + 1;
            }
        }

        async function handleAddToCart(productId = getProductId(), quantity) {
            const input = document.querySelector('.quantity-input');
            validateQuantity(input); // Validate trước khi lấy giá trị
            
            const selectedQuantity = typeof quantity === 'number' && !isNaN(quantity) && quantity > 0
                ? quantity
                : parseInt(input.value) || 1;

            // Kiểm tra số lượng hợp lệ
            if (selectedQuantity < 1) {
                alert('Số lượng phải lớn hơn 0!');
                input.value = 1;
                return;
            }

            if (selectedQuantity > 999) {
                alert('Số lượng tối đa là 999!');
                input.value = 999;
                return;
            }

            // Lấy size và màu đã chọn
            const selectedSizeElement = document.querySelector('.size-option.selected');
            const selectedColorElement = document.querySelector('.color-option.selected');
            
            const selectedSize = selectedSizeElement ? selectedSizeElement.textContent.trim() : 'M';
            const selectedColor = selectedColorElement ? rgbToColorName(selectedColorElement.style.backgroundColor) : 'Đen';
            
            console.log('Selected:', {productId, selectedQuantity, selectedSize, selectedColor});

            // Tìm variant ID từ server
            try {
                const variantResponse = await fetch(`/Product/FindOrCreateVariant?productId=${productId}&size=${selectedSize}&color=${encodeURIComponent(selectedColor)}`);
                const variantResult = await variantResponse.json();
                
                let variantId = null;
                if (variantResult.success && variantResult.variantId) {
                    variantId = variantResult.variantId;
                }

                // Gọi addToCart với variantId
                if (typeof window.addToCart === 'function') {
                    window.addToCart(productId, selectedQuantity, variantId);
                } else {
                    console.error('Global addToCart function is not available.');
                }
            } catch (error) {
                console.error('Error finding variant:', error);
                // Fallback: add without variant
                if (typeof window.addToCart === 'function') {
                    window.addToCart(productId, selectedQuantity, null);
                }
            }
        }

        // Helper function to convert RGB to color name
        function rgbToColorName(rgb) {
            const colorMap = {
                'rgb(0, 0, 0)': 'Đen',
                'rgb(255, 255, 255)': 'Trắng',
                'rgb(128, 128, 128)': 'Xám',
                'rgb(65, 105, 225)': 'Xanh',
                'rgb(139, 69, 19)': 'Nâu',
                'rgb(47, 79, 79)': 'Xanh đậm'
            };
            return colorMap[rgb] || 'Đen';
        }

        // Handle Buy Now button
        async function handleBuyNow() {
            const productId = getProductId();
            const input = document.querySelector('.quantity-input');
            validateQuantity(input);
            
            const selectedQuantity = parseInt(input.value) || 1;

            // Kiểm tra số lượng hợp lệ
            if (selectedQuantity < 1) {
                alert('Số lượng phải lớn hơn 0!');
                input.value = 1;
                return;
            }

            if (selectedQuantity > 999) {
                alert('Số lượng tối đa là 999!');
                input.value = 999;
                return;
            }

            // Lấy size và màu đã chọn
            const selectedSizeElement = document.querySelector('.size-option.selected');
            const selectedColorElement = document.querySelector('.color-option.selected');
            
            const selectedSize = selectedSizeElement ? selectedSizeElement.textContent.trim() : 'M';
            const selectedColor = selectedColorElement ? rgbToColorName(selectedColorElement.style.backgroundColor) : 'Đen';
            
            console.log('Buy Now Selected:', {productId, selectedQuantity, selectedSize, selectedColor});

            // Disable button để tránh click nhiều lần
            const buyNowBtn = document.getElementById('buyNowBtn');
            const originalText = buyNowBtn.innerHTML;
            buyNowBtn.disabled = true;
            buyNowBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...';

            try {
                // Lấy thông tin sản phẩm hiện tại từ trang
                const productName = document.getElementById('productTitle').textContent;
                const priceText = document.getElementById('currentPrice').textContent.replace(/[^\d]/g, '');
                const productPrice = parseInt(priceText) || 0;
                const productImage = document.getElementById('productImage').src;

                // Tìm variant ID từ server
                const variantResponse = await fetch(`/Product/FindOrCreateVariant?productId=${productId}&size=${selectedSize}&color=${encodeURIComponent(selectedColor)}`);
                const variantResult = await variantResponse.json();
                
                let variantId = null;
                if (variantResult.success && variantResult.variantId) {
                    variantId = variantResult.variantId;
                }

                // Gọi API thêm vào giỏ hàng
                const response = await fetch('/Cart/AddToCart', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        productId: productId,
                        quantity: selectedQuantity,
                        variantId: variantId
                    })
                });

                const result = await response.json();
                
                if (result.success) {
                    // Lưu thông tin sản phẩm vào localStorage để Checkout page có thể đọc
                    const selectedProduct = {
                        productId: productId,
                        name: productName,
                        price: productPrice,
                        quantity: selectedQuantity,
                        size: selectedSize,
                        color: selectedColor,
                        image: productImage,
                        variantId: variantId
                    };
                    
                    // Lưu vào localStorage với key mà Checkout page sử dụng
                    localStorage.setItem('unistyleSelectedProducts', JSON.stringify([selectedProduct]));
                    console.log('Saved to localStorage:', selectedProduct);
                    
                    // Chuyển hướng đến trang checkout
                    window.location.href = '/Checkout';
                } else {
                    alert(result.message || 'Có lỗi xảy ra khi mua hàng!');
                    // Reset button
                    buyNowBtn.disabled = false;
                    buyNowBtn.innerHTML = originalText;
                }
            } catch (error) {
                console.error('Error buying now:', error);
                alert('Có lỗi xảy ra khi mua hàng!');
                // Reset button
                buyNowBtn.disabled = false;
                buyNowBtn.innerHTML = originalText;
            }
        }

        async function toggleLike() {
            const likeBtn = document.getElementById('likeBtn');
            const icon = likeBtn.querySelector('i');
            const productId = getProductId();
            
            // Disable button while processing
            likeBtn.disabled = true;
            
            try {
                // Call API to toggle favorite
                const response = await fetch('/Favorites/ToggleFavorite', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ productId: productId })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    // Update UI based on result
                    if (result.isAdded) {
                        // Added to favorites
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        likeBtn.classList.remove('btn-outline-dark');
                        likeBtn.classList.add('btn-danger');
                    } else {
                        // Removed from favorites
                        icon.classList.remove('fas');
                        icon.classList.add('far');
                        likeBtn.classList.remove('btn-danger');
                        likeBtn.classList.add('btn-outline-dark');
                    }
                    
                    // Show toast
                    if (typeof showToast === 'function') {
                        showToast(result.message);
                    }
                    
                    // Update favorites badge
                    if (typeof window.updateFavoritesBadge === 'function') {
                        window.updateFavoritesBadge();
                    }
                } else {
                    alert(result.message || 'Có lỗi xảy ra!');
                }
            } catch (error) {
                console.error('Error toggling favorite:', error);
                alert('Có lỗi xảy ra khi thêm vào yêu thích!');
            } finally {
                // Re-enable button
                likeBtn.disabled = false;
            }
        }

        // ==================== COMMENTS & REVIEWS ====================
        
        let commentsSkip = 0;
        const commentsTake = 5;
        let allCommentsData = [];
        let totalCommentsCount = 0;
        
        // Load comments for product
        async function loadComments(reset = true, scrollToComment = null) {
            const productId = getProductId();
            if (reset) {
                commentsSkip = 0;
                allCommentsData = [];
            }
            
            try {
                // If we need to scroll to a specific comment, load more to ensure it's visible
                let take = commentsTake;
                if (scrollToComment && reset) {
                    take = 50; // Load more to find the comment
                }
                
                const response = await fetch(`/Product/GetComments?productId=${productId}&skip=${commentsSkip}&take=${take}`);
                const result = await response.json();
                
                if (result.success && result.comments) {
                    if (reset) {
                        allCommentsData = result.comments;
                        totalCommentsCount = result.totalCount || result.comments.length;
                        commentsSkip = result.comments.length; // Update skip to reflect loaded comments
                    } else {
                        allCommentsData = [...allCommentsData, ...result.comments];
                        commentsSkip += result.comments.length; // Update skip
                    }
                    
                    // If we need to scroll to a comment but it's not in the list yet, load more
                    if (scrollToComment && reset) {
                        const commentExists = allCommentsData.some(c => 
                            c.productId === scrollToComment.productId && 
                            c.customerId === scrollToComment.customerId
                        );
                        
                        if (!commentExists && result.hasMore) {
                            // Load more comments to find the target comment
                            let moreSkip = allCommentsData.length; // Start from where we left off
                            while (moreSkip < totalCommentsCount) {
                                const moreResponse = await fetch(`/Product/GetComments?productId=${productId}&skip=${moreSkip}&take=${commentsTake}`);
                                const moreResult = await moreResponse.json();
                                if (moreResult.success && moreResult.comments && moreResult.comments.length > 0) {
                                    allCommentsData = [...allCommentsData, ...moreResult.comments];
                                    commentsSkip = allCommentsData.length; // Update skip to total loaded
                                    const found = moreResult.comments.some(c => 
                                        c.productId === scrollToComment.productId && 
                                        c.customerId === scrollToComment.customerId
                                    );
                                    if (found || !moreResult.hasMore) break;
                                    moreSkip = allCommentsData.length;
                                } else {
                                    break;
                                }
                            }
                        }
                    }
                    
                    // Calculate if there are more comments to load
                    const hasMoreToShow = allCommentsData.length < totalCommentsCount;
                    displayComments(allCommentsData, hasMoreToShow);
                    displayRatingSummary(allCommentsData);
                    
                    // Scroll to specific comment if provided
                    if (scrollToComment) {
                        setTimeout(() => {
                            const commentElement = document.querySelector(`[data-comment-id="${scrollToComment.productId}-${scrollToComment.customerId}"]`);
                            if (commentElement) {
                                commentElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
                                commentElement.style.backgroundColor = '#fff3cd';
                                commentElement.style.transition = 'background-color 0.3s';
                                setTimeout(() => {
                                    commentElement.style.backgroundColor = '';
                                }, 3000);
                            }
                        }, 200);
                    }
                }
            } catch (error) {
                console.error('Error loading comments:', error);
            }
        }

        // Load more comments
        async function loadMoreComments() {
            commentsSkip += commentsTake;
            await loadComments(false);
        }

        // Display comments list
        function displayComments(comments, hasMore = false) {
            const container = document.getElementById('commentsList');
            
            if (!comments || comments.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-4 text-muted">
                        <i class="fas fa-comments fa-3x mb-3"></i>
                        <p>Chưa có bình luận nào. Hãy là người đầu tiên!</p>
                    </div>`;
                return;
            }

            let html = '';
            comments.forEach(comment => {
                const stars = '★'.repeat(comment.rating) + '☆'.repeat(5 - comment.rating);
                const date = new Date(comment.commentDate).toLocaleDateString('vi-VN');
                const customerName = comment.customerName || 'Khách hàng';
                const initial = customerName.charAt(0).toUpperCase();
                const isPending = !comment.isPublished;
                const pendingBadge = isPending ? '<span class="badge bg-warning text-dark ms-2">Đang chờ duyệt</span>' : '';
                
                html += `
                    <div class="comment-item ${isPending ? 'comment-pending' : ''}" data-comment-id="${comment.productId}-${comment.customerId}">
                        <div class="comment-author">
                            <div class="comment-avatar">${initial}</div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong class="d-block">${customerName}${pendingBadge}</strong>
                                        <div class="comment-stars">${stars}</div>
                                    </div>
                                    <small class="text-muted">${date}</small>
                                </div>
                            </div>
                        </div>
                        ${comment.content ? `<p class="mb-0 text-secondary mt-2">${comment.content}</p>` : ''}
                    </div>`;
            });
            
            // Add "Xem thêm" button if there are more comments
            if (hasMore) {
                html += `
                    <div class="text-center mt-4">
                        <button class="btn btn-outline-primary" onclick="loadMoreComments()">
                            <i class="fas fa-chevron-down me-2"></i>Xem thêm bình luận
                        </button>
                    </div>`;
            }
            
            container.innerHTML = html;
        }

        // Display rating summary
        function displayRatingSummary(comments) {
            if (!comments || comments.length === 0) return;

            const publishedComments = comments.filter(c => c.isPublished);
            const totalReviews = publishedComments.length;
            
            if (totalReviews === 0) return;

            // Calculate average rating
            const avgRating = publishedComments.reduce((sum, c) => sum + c.rating, 0) / totalReviews;
            document.getElementById('averageRating').textContent = avgRating.toFixed(1);
            document.getElementById('totalReviews').textContent = totalReviews;

            // Update stars
            const starsHtml = '★'.repeat(Math.round(avgRating)) + '☆'.repeat(5 - Math.round(avgRating));
            document.getElementById('averageStars').innerHTML = `<span class="text-warning fs-4">${starsHtml}</span>`;

            // Rating breakdown
            const breakdown = [5, 4, 3, 2, 1].map(rating => {
                const count = publishedComments.filter(c => c.rating === rating).length;
                const percentage = (count / totalReviews * 100).toFixed(0);
                return { rating, count, percentage };
            });

            let breakdownHtml = '';
            breakdown.forEach(item => {
                breakdownHtml += `
                    <div class="rating-breakdown-item">
                        <div class="rating-breakdown-label">${item.rating} ★</div>
                        <div class="rating-breakdown-bar">
                            <div class="rating-breakdown-fill" style="width: ${item.percentage}%"></div>
                        </div>
                        <div class="rating-breakdown-count">${item.count}</div>
                    </div>`;
            });
            document.getElementById('ratingBreakdown').innerHTML = breakdownHtml;
        }

        // Rating input buttons (new design)
        const ratingTexts = ['', 'Rất tệ', 'Tệ', 'Bình thường', 'Tốt', 'Xuất sắc'];
        
        document.querySelectorAll('.rating-star-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const rating = parseInt(this.dataset.rating);
                document.getElementById('ratingInput').value = rating;
                
                // Update text
                document.getElementById('ratingText').textContent = ratingTexts[rating];
                
                // Update visual - remove active from all
                document.querySelectorAll('.rating-star-btn').forEach(b => {
                    b.classList.remove('active');
                    b.querySelector('i').classList.remove('fas');
                    b.querySelector('i').classList.add('far');
                });
                
                // Add active to selected and previous
                document.querySelectorAll('.rating-star-btn').forEach((b, index) => {
                    if (index < rating) {
                        b.classList.add('active');
                        b.querySelector('i').classList.remove('far');
                        b.querySelector('i').classList.add('fas');
                    }
                });
            });
        });

        // Submit review form
        document.getElementById('reviewForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const rating = parseInt(document.getElementById('ratingInput').value);
            const content = document.getElementById('commentContent').value.trim();
            
            if (rating === 0) {
                alert('Vui lòng chọn số sao đánh giá!');
                return;
            }

            const productId = getProductId();
            
            try {
                const response = await fetch('/Product/AddComment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, rating, content })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    if (typeof showToast === 'function') {
                        showToast('Cảm ơn bạn đã đánh giá! Bình luận của bạn đang chờ duyệt.');
                    } else {
                        alert('Cảm ơn bạn đã đánh giá! Bình luận của bạn đang chờ duyệt.');
                    }
                    
                    // Reset form
                    this.reset();
                    document.getElementById('ratingInput').value = 0;
                    document.getElementById('ratingText').textContent = 'Chọn số sao đánh giá';
                    document.querySelectorAll('.rating-star-btn').forEach(btn => {
                        btn.classList.remove('active');
                        btn.querySelector('i').classList.remove('fas');
                        btn.querySelector('i').classList.add('far');
                    });
                    
                    // Reload comments and scroll to user's comment
                    if (result.comment) {
                        // Use the comment info returned from server
                        setTimeout(async () => {
                            await loadComments(true, result.comment);
                        }, 500);
                    } else {
                        // Fallback: reload comments normally
                        setTimeout(async () => {
                            await loadComments(true);
                        }, 500);
                    }
                } else {
                    alert(result.message || 'Có lỗi xảy ra. Vui lòng thử lại!');
                }
            } catch (error) {
                console.error('Error submitting review:', error);
                alert('Có lỗi xảy ra. Vui lòng thử lại!');
            }
        });

        // Check and update favorite button state on load
        async function updateFavoriteButtonState() {
            const productId = getProductId();
            const likeBtn = document.getElementById('likeBtn');
            const icon = likeBtn?.querySelector('i');
            
            if (!likeBtn || !icon) return;
            
            try {
                const response = await fetch(`/Favorites/CheckFavorite?productId=${productId}`);
                const result = await response.json();
                
                if (result.success && result.isFavorite) {
                    // Product is in favorites
                    icon.classList.remove('far');
                    icon.classList.add('fas');
                    likeBtn.classList.remove('btn-outline-dark');
                    likeBtn.classList.add('btn-danger');
                }
            } catch (error) {
                console.error('Error checking favorite:', error);
            }
        }

        // Load product on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadProduct();
            loadComments();
            updateFavoriteButtonState();
        });
    </script>
}
