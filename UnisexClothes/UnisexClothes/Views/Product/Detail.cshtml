                    <div class="card-body">
                        <h5 class="card-title product-title">Áo Khoác UniStyle</h5>
                        <p class="product-price">599.000 ₫</p>
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="3" class="btn btn-outline-dark w-100">Xem chi tiết</a>
                    </div>
