@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<section class="py-5">
    <div class="container">
        <div class="row">
            <!-- Product Image -->
            <div class="col-md-6">
                <img id="productImage" src="" class="product-detail-img" alt="Product">
            </div>

            <!-- Product Info -->
            <div class="col-md-6">
                <h1 id="productTitle" class="fw-bold mb-3"></h1>
                <p id="productCode" class="text-muted mb-3"></p>
                
                <!-- Price -->
                <div class="mb-4">
                    <h2 id="currentPrice" class="fw-bold text-danger mb-0"></h2>
                    <small id="originalPrice" class="text-muted text-decoration-line-through"></small>
                </div>

                <!-- Description -->
                <div id="productDescription" class="mb-4">
                    <h5 class="fw-bold">Mô tả sản phẩm</h5>
                    <p id="descriptionText"></p>
                    <ul id="descriptionList"></ul>
                </div>

                <!-- Size Selection -->
                <div class="mb-4">
                    <h5 class="fw-bold mb-3">Kích thước</h5>
                    <div class="d-flex gap-2">
                        <div class="size-option" onclick="selectSize(this)">S</div>
                        <div class="size-option selected" onclick="selectSize(this)">M</div>
                        <div class="size-option" onclick="selectSize(this)">L</div>
                        <div class="size-option" onclick="selectSize(this)">XL</div>
                    </div>
                </div>

                <!-- Color Selection -->
                <div class="mb-4">
                    <h5 class="fw-bold mb-3">Màu sắc</h5>
                    <div id="colorOptions"></div>
                </div>

                <!-- Quantity -->
                <div class="mb-4">
                    <h5 class="fw-bold mb-3">Số lượng</h5>
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-outline-dark" onclick="decreaseQuantity()">-</button>
                        <input type="number" class="form-control quantity-input" value="1" min="1" max="999" 
                               oninput="validateQuantity(this)" onchange="validateQuantity(this)" 
                               style="width: 80px; text-align: center;">
                        <button class="btn btn-outline-dark" onclick="increaseQuantity()">+</button>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="mb-4">
                    <div class="d-flex gap-3 mb-3">
                        <button id="addToCartBtn" class="btn btn-outline-dark flex-grow-1" onclick="handleAddToCart()">
                            <i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ hàng
                        </button>
                        <button id="likeBtn" class="btn btn-outline-dark" onclick="toggleLike()">
                            <i class="far fa-heart"></i>
                        </button>
                    </div>
                    <button id="buyNowBtn" class="btn btn-unistyle w-100" onclick="handleBuyNow()">
                        <i class="fas fa-shopping-bag me-2"></i>MUA NGAY
                    </button>
                </div>

                <!-- Shipping Info -->
                <div class="border-top pt-4">
                    <div class="d-flex align-items-start mb-3">
                        <i class="fas fa-truck text-success fa-2x me-3"></i>
                        <div>
                            <h6 class="fw-bold">Miễn phí vận chuyển</h6>
                            <p class="text-muted mb-0">Cho đơn hàng trên 500.000 ₫</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start mb-3">
                        <i class="fas fa-undo text-success fa-2x me-3"></i>
                        <div>
                            <h6 class="fw-bold">Đổi trả miễn phí</h6>
                            <p class="text-muted mb-0">Trong 7 ngày đầu</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start">
                        <i class="fas fa-shield-alt text-success fa-2x me-3"></i>
                        <div>
                            <h6 class="fw-bold">Bảo hành chính hãng</h6>
                            <p class="text-muted mb-0">1 năm cho tất cả sản phẩm</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Reviews & Comments Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold mb-2">Đánh giá từ khách hàng</h2>
            <p class="text-muted">Chia sẻ trải nghiệm của bạn về sản phẩm này</p>
        </div>

        <div class="row g-4">
            <!-- Left Column: Rating Summary -->
            <div class="col-lg-4">
                <!-- Overall Rating Card -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body text-center p-4">
                        <h1 class="display-2 fw-bold text-primary mb-2" id="averageRating">0.0</h1>
                        <div class="mb-3" id="averageStars" style="font-size: 1.8rem; color: #ffc107;">
                            ☆☆☆☆☆
                        </div>
                        <p class="text-muted mb-0">Dựa trên <strong id="totalReviews">0</strong> đánh giá</p>
                    </div>
                </div>

                <!-- Rating Breakdown Card -->
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3">Phân bố đánh giá</h6>
                        <div id="ratingBreakdown">
                            <!-- Rating bars will be inserted here -->
                            <div class="text-muted small">Chưa có đánh giá</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Write Review & Comments -->
            <div class="col-lg-8">
                <!-- Write Review Form -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">
                            <i class="fas fa-star text-warning me-2"></i>Viết đánh giá của bạn
                        </h5>
                        <form id="reviewForm">
                            <div class="mb-4">
                                <label class="form-label fw-semibold mb-3">Bạn đánh giá sao về sản phẩm này? <span class="text-danger">*</span></label>
                                <div class="rating-input-modern d-flex gap-2 mb-2">
                                    <button type="button" class="rating-star-btn" data-rating="1">
                                        <i class="far fa-star"></i>
                                        <span class="rating-label">1</span>
                                    </button>
                                    <button type="button" class="rating-star-btn" data-rating="2">
                                        <i class="far fa-star"></i>
                                        <span class="rating-label">2</span>
                                    </button>
                                    <button type="button" class="rating-star-btn" data-rating="3">
                                        <i class="far fa-star"></i>
                                        <span class="rating-label">3</span>
                                    </button>
                                    <button type="button" class="rating-star-btn" data-rating="4">
                                        <i class="far fa-star"></i>
                                        <span class="rating-label">4</span>
                                    </button>
                                    <button type="button" class="rating-star-btn" data-rating="5">
                                        <i class="far fa-star"></i>
                                        <span class="rating-label">5</span>
                                    </button>
                                </div>
                                <small class="text-muted" id="ratingText">Chọn số sao đánh giá</small>
                                <input type="hidden" id="ratingInput" value="0">
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-semibold">Chia sẻ trải nghiệm của bạn</label>
                                <textarea id="commentContent" class="form-control" rows="4" 
                                    placeholder="Sản phẩm có chất lượng tốt không? Bạn thích điểm gì nhất?"></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="fas fa-paper-plane me-2"></i>Gửi đánh giá
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Comments List -->
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">
                            <i class="fas fa-comments text-primary me-2"></i>Bình luận từ khách hàng
                        </h5>
                        <div id="commentsList">
                            <div class="text-center py-5 text-muted">
                                <i class="fas fa-comment-dots fa-3x mb-3 opacity-25"></i>
                                <p class="mb-0">Chưa có bình luận nào. Hãy là người đầu tiên đánh giá!</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Related Products Section -->
