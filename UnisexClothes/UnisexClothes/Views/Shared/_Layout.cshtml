<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniStyle</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chatbox.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        /* 🔧🔧🔧 CRITICAL FIX: GLOBAL BACKDROP POINTER-EVENTS & OPACITY FIX 🔧🔧🔧 */
        .modal-backdrop {
            pointer-events: none !important;
            opacity: 0.15 !important; /* Giảm opacity để nền sáng hơn */
            background-color: rgba(0, 0, 0, 0.2) !important; /* Nền nhạt hơn */
        }
        .modal-backdrop.show {
            pointer-events: none !important;
            opacity: 0.15 !important;
        }
        .modal-backdrop.fade {
            pointer-events: none !important;
        }
        .modal-backdrop.fade.show {
            opacity: 0.15 !important;
        }
        /* End Critical Fix */
        
        /* Animated Background - Black & White Stripes */
        body {
            position: relative;
            overflow-x: hidden;
        }
        
        #main-animated-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: 
                linear-gradient(180deg, 
                    #ffffff 0%, 
                    #ffffff 25%, 
                    #f8f9fa 25%, 
                    #f8f9fa 50%, 
                    #ffffff 50%, 
                    #ffffff 75%, 
                    #f8f9fa 75%, 
                    #f8f9fa 100%
                );
            background-size: 100% 400%;
            animation: slideMainBg 40s linear infinite;
        }
        
        @@keyframes slideMainBg {
            0% { background-position: 0% 0%; }
            100% { background-position: 0% 100%; }
        }
        
        /* Halftone dots pattern */
        #main-animated-bg::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                radial-gradient(circle at 25% 25%, rgba(0, 0, 0, 0.08) 2%, transparent 2%),
                radial-gradient(circle at 75% 75%, rgba(0, 0, 0, 0.08) 2%, transparent 2%),
                radial-gradient(circle at 25% 75%, rgba(0, 0, 0, 0.05) 2%, transparent 2%),
                radial-gradient(circle at 75% 25%, rgba(0, 0, 0, 0.05) 2%, transparent 2%);
            background-size: 25px 25px;
            background-position: 0 0, 12.5px 12.5px, 0 12.5px, 12.5px 0;
            animation: dotsFade 4s ease-in-out infinite alternate;
        }
        
        @@keyframes dotsFade {
            0% { opacity: 0.4; }
            100% { opacity: 0.7; }
        }
        
        /* Floating particles */
        .home-particle {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
            opacity: 0.06;
        }
        
        .home-particle.light {
            background: radial-gradient(circle, #ffffff, rgba(255, 255, 255, 0.3));
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
        }
        
        .home-particle.dark {
            background: radial-gradient(circle, #1a1a1a, rgba(0, 0, 0, 0.3));
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.1);
        }
        
        @@keyframes floatHome {
            0%, 100% {
                transform: translateY(0) translateX(0);
            }
            25% {
                transform: translateY(-25px) translateX(20px);
            }
            50% {
                transform: translateY(-50px) translateX(-20px);
            }
            75% {
                transform: translateY(-25px) translateX(-25px);
            }
        }
        
        /* Ensure content is above background */
        .navbar, main, footer {
            position: relative;
            z-index: 1;
        }

        /* Account Dropdown Styles */
        .nav-item.dropdown .nav-link:hover {
            background-color: #e9ecef !important;
            transform: translateY(-1px);
            transition: all 0.2s ease;
        }

        .dropdown-menu .dropdown-item {
            transition: all 0.2s ease;
        }

        .dropdown-menu .dropdown-item:hover {
            background-color: #f8f9fa;
            padding-left: 20px !important;
            transform: translateX(5px);
        }

        .dropdown-menu .dropdown-item.text-danger:hover {
            background-color: #ffe0e0;
            color: #dc3545 !important;
        }

        /* Navbar optimization for better display */
        .navbar-nav .nav-link {
            padding-left: 0.5rem !important;
            padding-right: 0.5rem !important;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .navbar-nav .nav-item.dropdown .nav-link {
            padding-left: 0.6rem !important;
            padding-right: 0.6rem !important;
        }

        .navbar-brand img {
            height: 35px;
        }

        /* Ensure dropdown menu is always visible */
        .navbar-nav .dropdown-menu {
            z-index: 9999;
        }

        /* Make account dropdown more compact */
        .nav-item.dropdown .nav-link {
            padding: 6px 12px !important;
        }

        /* User pills */
        .user-pill-group {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .user-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 6px 16px;
            border-radius: 999px;
            background: linear-gradient(135deg, #1d1d1d 0%, #3b3b3b 100%);
            color: #fff;
            font-weight: 600;
            font-size: 0.9rem;
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.18);
        }

        .user-pill--admin {
            background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
        }

        .logout-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 6px 16px;
            border-radius: 999px;
            font-weight: 600;
            font-size: 0.9rem;
            border: 1px solid transparent;
            text-decoration: none;
            transition: all 0.2s ease, transform 0.2s ease;
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
        }

        .logout-pill--ghost {
            background-color: #f4f4f4;
            color: #1a1a1a;
            border-color: #e5e5e5;
        }

        .logout-pill--primary {
            background: linear-gradient(135deg, #1f1f1f 0%, #3a3a3a 100%);
            color: #f8f9fa;
            border: 1px solid rgba(255, 255, 255, 0.12);
        }

        .logout-pill:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
        }

        .logout-pill--ghost:hover {
            background-color: #212529;
            border-color: #212529;
            color: #fff;
        }

        .logout-pill--primary:hover {
            background: linear-gradient(135deg, #000000 0%, #2b2b2b 100%);
            color: #fff;
        }

        .nav-link--reward {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 600;
        }

        .nav-link--reward .reward-icon {
            background: inherit;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .navbar-nav .nav-link.active {
            color: #fff !important;
            background: linear-gradient(135deg, #111111 0%, #2a2a2a 100%);
            border-radius: 24px;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.15);
            -webkit-text-fill-color: #fff !important;
            -webkit-background-clip: border-box !important;
        }

        @@media (max-width: 575.98px) {
            .user-pill-group {
                flex-direction: column;
                align-items: stretch;
                width: 100%;
            }

            .user-pill,
            .logout-pill {
                width: 100%;
                justify-content: center;
            }
        }

        @@media (min-width: 1200px) and (max-width: 1499px) {
            .navbar-nav .nav-link {
                padding-left: 0.4rem !important;
                padding-right: 0.4rem !important;
                font-size: 0.85rem;
            }
            
            .navbar-brand img {
                height: 32px !important;
            }

            .nav-item.dropdown .nav-link {
                padding: 5px 10px !important;
                font-size: 0.85rem !important;
            }
        }
    </style>
</head>
<body>
    <!-- Animated Background -->
    <div id="main-animated-bg"></div>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-xxl navbar-light bg-white border-bottom" style="min-height: 70px;">
        <div class="container">
            <a class="navbar-brand fw-bold text-dark" asp-controller="Home" asp-action="Index">
                <img src="~/images/LogovsBrandingUniSex/logo.png" height="40" class="me-2" alt="UniStyle">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @{
                        string NavActive(string controller, string action = null)
                        {
                            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                            var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                            var controllerMatch = string.Equals(controller, currentController, StringComparison.OrdinalIgnoreCase);
                            var actionMatch = action == null || string.Equals(action, currentAction, StringComparison.OrdinalIgnoreCase);
                            return controllerMatch && actionMatch ? "active" : string.Empty;
                        }
                    }
                    <li class="nav-item">
                        <a class="nav-link text-dark @(NavActive("Home", "Index"))" asp-controller="Home" asp-action="Index">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark @(NavActive("Product", "Shop"))" asp-controller="Product" asp-action="Shop">Cửa hàng</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link--reward @(NavActive("SpinWheel", "Index"))" asp-controller="SpinWheel" asp-action="Index">
                            <i class="fas fa-gift reward-icon"></i> Vòng quay may mắn
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark position-relative @(NavActive("SpinWheel", "MyVouchers"))" asp-controller="SpinWheel" asp-action="MyVouchers">
                            <i class="fas fa-wallet me-1"></i>Kho voucher
                            <span class="badge bg-success position-absolute top-0 start-100 translate-middle rounded-pill" id="voucherBadge" style="font-size: 0.7rem; padding: 3px 7px; display: none;">0</span>
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#" data-bs-toggle="modal" data-bs-target="#searchModal">
                            <i class="fas fa-search me-1"></i>Tìm kiếm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark position-relative @(NavActive("Favorites", "Index"))" asp-controller="Favorites" asp-action="Index">
                            <i class="fas fa-heart me-1"></i>Yêu thích
                            <span class="badge bg-danger position-absolute top-0 start-100 translate-middle rounded-pill" id="favoritesBadge" style="font-size: 0.7rem; padding: 3px 7px; display: none;">0</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark position-relative @(NavActive("Cart", "Index"))" asp-controller="Cart" asp-action="Index">
                            <i class="fas fa-shopping-cart me-1"></i>Giỏ hàng
                            <span class="badge bg-danger position-absolute top-0 start-100 translate-middle rounded-pill" id="cartBadge" style="font-size: 0.7rem; padding: 3px 7px; display: none;">0</span>
                        </a>
                    </li>
                    @{
                        var isAdminLoggedIn = Context.Session.GetString("AdminLoggedIn") == "true";
                        var isUserLoggedIn = Context.Session.GetString("UserLoggedIn") == "true";
                        var adminUserName = Context.Session.GetString("AdminUsername") ?? "Admin";
                        var userName = Context.Session.GetString("UserName") ?? Context.Session.GetString("UserEmail")?.Split('@')[0] ?? "User";
                        var ordersLink = isUserLoggedIn || isAdminLoggedIn
                            ? Url.Action("MyOrders", "Account")
                            : Url.Action("Login", "Account");
                    }
                    <li class="nav-item">
                        <a class="nav-link text-dark position-relative @(NavActive("Account", "MyOrders"))" href="@ordersLink">
                            <i class="fas fa-shopping-bag me-1"></i>Đơn hàng
                        </a>
                    </li>
                    @if (isAdminLoggedIn)
                    {
                        <li class="nav-item d-flex align-items-center">
                            <div class="user-pill-group">
                                <span class="user-pill user-pill--admin">
                                    <i class="fas fa-user-shield"></i>@adminUserName
                                </span>
                                <a class="logout-pill logout-pill--ghost" asp-controller="Admin" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt"></i>Đăng xuất
                                </a>
                            </div>
                        </li>
                    }
                    else if (isUserLoggedIn)
                    {
                        <li class="nav-item d-flex align-items-center">
                            <div class="user-pill-group">
                                <span class="user-pill">
                                    <i class="fas fa-user-circle"></i>@userName
                                </span>
                                <a class="logout-pill logout-pill--primary" href="#" onclick="if(confirm('Bạn có chắc muốn đăng xuất?')) { logoutUser(); } return false;">
                                    <i class="fas fa-sign-out-alt"></i>Đăng xuất
                                </a>
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-user me-1"></i>Tài khoản
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Toast Notification Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
        <div id="toast" class="toast" role="alert" aria-live="assertive" aria-atomic="true" style="min-width: 350px;">
            <div class="toast-header bg-success text-white d-flex justify-content-between align-items-center">
                <strong class="d-flex align-items-center"><i class="fas fa-check-circle me-2"></i>Thành công!</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body bg-light fs-5" id="toastMessage" style="padding: 15px;">
                <i class="fas fa-check-circle text-success me-2"></i>Đã thêm sản phẩm vào giỏ hàng!
            </div>
        </div>
    </div>

    <!-- Floating Gift Button -->
    <a href="/SpinWheel/Index" class="floating-gift-btn" title="Vòng quay may mắn - Nhận quà miễn phí!">
        <i class="fas fa-gift gift-icon"></i>
        <span class="gift-text">Quà<br>Miễn Phí</span>
    </a>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white mt-5">
        <div class="container py-5">
            <div class="row g-4">
                <!-- About UniStyle -->
                <div class="col-md-6 col-lg-4">
                    <h5 class="fw-bold mb-4">
                        <img src="~/images/LogovsBrandingUniSex/logo.png" height="30" class="me-2" alt="UniStyle">
                    </h5>
                    <p class="text-white-50 mb-3">
                        Thời trang Unisex hiện đại, phong cách trẻ trung và năng động. 
                        Chất lượng cao, giá cả hợp lý, phục vụ tận tâm.
                    </p>
                    <div class="d-flex gap-2 mb-3">
                        <a href="#" class="btn btn-outline-light btn-sm rounded-circle" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="#" class="btn btn-outline-light btn-sm rounded-circle" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;">
                            <i class="fab fa-instagram"></i>
                        </a>
                        <a href="#" class="btn btn-outline-light btn-sm rounded-circle" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;">
                            <i class="fab fa-tiktok"></i>
                        </a>
                        <a href="#" class="btn btn-outline-light btn-sm rounded-circle" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;">
                            <i class="fab fa-youtube"></i>
                        </a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="col-md-6 col-lg-2">
                    <h6 class="fw-bold mb-3 text-uppercase">Về chúng tôi</h6>
                    <ul class="list-unstyled footer-links">
                        <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Giới thiệu</a></li>
                        <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Tuyển dụng</a></li>
                        <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Liên hệ</a></li>
                        <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Hệ thống cửa hàng</a></li>
                    </ul>
                </div>

                <!-- Support -->
                <div class="col-md-6 col-lg-3">
                    <h6 class="fw-bold mb-3 text-uppercase">Hỗ trợ</h6>
                    <ul class="list-unstyled footer-links">
                        <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Chính sách đổi trả</a></li>
                        <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Chính sách bảo hành</a></li>
                        <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Chính sách giao hàng</a></li>
                        <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Hướng dẫn mua hàng</a></li>
                        <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none">Câu hỏi thường gặp</a></li>
                    </ul>
                </div>

                <!-- Contact Info -->
                <div class="col-md-6 col-lg-3">
                    <h6 class="fw-bold mb-3 text-uppercase">Liên hệ</h6>
                    <ul class="list-unstyled text-white-50">
                        <li class="mb-2">
                            <i class="fas fa-map-marker-alt me-2"></i>
                            123 Nguyễn Văn A, Q.1, TP.HCM
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-phone me-2"></i>
                            <a href="tel:0901234567" class="text-white-50 text-decoration-none">0901.234.567</a>
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-envelope me-2"></i>
                            <a href="mailto:cskh@unistyle.com" class="text-white-50 text-decoration-none">cskh@unistyle.com</a>
                        </li>
