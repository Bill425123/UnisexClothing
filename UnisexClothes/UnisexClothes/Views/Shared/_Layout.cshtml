            </div>
        </div>
    </footer>

    <!-- Search Modal -->
    <div class="modal fade" id="searchModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Tìm kiếm sản phẩm</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="input-group">
                        <input type="text" class="form-control" placeholder="Nhập tên sản phẩm..." id="globalSearchInput">
                        <button class="btn btn-dark" type="button" id="globalSearchBtn">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // 🔧🔧🔧 CRITICAL FIX: GLOBAL BACKDROP POINTER-EVENTS FIX 🔧🔧🔧
        (function() {
            console.log('🔧 GLOBAL BACKDROP FIX LOADED (Frontend)');
            
            // MutationObserver - bắt backdrop ngay khi tạo
            const backdropObserver = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    mutation.addedNodes.forEach(function(node) {
                        if (node.classList && node.classList.contains('modal-backdrop')) {
                            node.style.pointerEvents = 'none';
                            node.style.opacity = '0.15';
                            node.style.setProperty('pointer-events', 'none', 'important');
                            node.style.setProperty('opacity', '0.15', 'important');
                            console.log('🔧 MutationObserver: Fixed backdrop');
                        }
                    });
                });
            });
            backdropObserver.observe(document.body, { childList: true });
            
            // Fix existing backdrops
            function fixBackdrops() {
                const backdrops = document.querySelectorAll('.modal-backdrop');
                backdrops.forEach(backdrop => {
                    backdrop.style.pointerEvents = 'none';
                    backdrop.style.opacity = '0.15';
                    backdrop.style.setProperty('pointer-events', 'none', 'important');
                    backdrop.style.setProperty('opacity', '0.15', 'important');
                });
            }
            
            // Fix on load
            document.addEventListener('DOMContentLoaded', fixBackdrops);
            
            // Fix every 500ms
            setInterval(fixBackdrops, 500);
            
            // Fix on modal show/shown
            document.addEventListener('show.bs.modal', function() {
                setTimeout(fixBackdrops, 10);
            }, true);
            document.addEventListener('shown.bs.modal', function() {
                setTimeout(fixBackdrops, 10);
            }, true);
            
            console.log('✅ Frontend backdrop fix ready');
        })();
        
        document.addEventListener('DOMContentLoaded', function () {

            // ================== CART BADGE ==================
            // Function updateCartBadge() được định nghĩa trong site.js
            // Gọi function từ site.js
            if (typeof window.updateCartBadge === 'function') {
                window.updateCartBadge();
            }

            // ================== FAVORITES BADGE ==================
            updateFavoritesBadge();

            // ================== VOUCHER BADGE ==================
            updateVoucherBadge();

            // ================== ADD TO CART ==================
            // Function addToCart() được định nghĩa trong site.js

            // ================== GLOBAL SEARCH ==================
            const globalSearchInput = document.getElementById('globalSearchInput');
            const globalSearchBtn = document.getElementById('globalSearchBtn');
            const searchModalEl = document.getElementById('searchModal');

            function triggerGlobalSearch() {
                if (!globalSearchInput) return;
                const keyword = globalSearchInput.value.trim();
                if (!keyword) { globalSearchInput.focus(); return; }
                if (searchModalEl && typeof bootstrap !== 'undefined') {
                    const modalInstance = bootstrap.Modal.getOrCreateInstance(searchModalEl);
                    modalInstance.hide();
                }
                const targetUrl = `/Product/Shop?keyword=${encodeURIComponent(keyword)}`;
                window.location.href = targetUrl;
            }

            if (globalSearchBtn) globalSearchBtn.addEventListener('click', triggerGlobalSearch);
            if (globalSearchInput) {
                globalSearchInput.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        triggerGlobalSearch();
                    }
                });
            }

            // ================== LOGOUT USER ==================
            window.logoutUser = function () {
                fetch('/Account/Logout', { method: 'POST' })
                    .then(() => { window.location.reload(); })
                    .catch(() => { alert('Đăng xuất thất bại!'); });
            };
        });

        // ================== UPDATE VOUCHER BADGE ==================
        async function updateVoucherBadge() {
            try {
                const response = await fetch('/SpinWheel/GetVoucherCount');
                const result = await response.json();
                
                const badge = document.getElementById('voucherBadge');
                if (badge && result.success) {
                    if (result.count > 0) {
                        badge.textContent = result.count;
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            } catch (error) {
                console.error('Error updating voucher badge:', error);
            }
        }

        // Expose to global scope for other pages to call
        window.updateVoucherBadge = updateVoucherBadge;

        // ================== UPDATE FAVORITES BADGE ==================
        async function updateFavoritesBadge() {
            try {
                const response = await fetch('/Favorites/GetFavoritesCount');
                const result = await response.json();
                
                const badge = document.getElementById('favoritesBadge');
                if (badge && result.success) {
                    if (result.count > 0) {
                        badge.textContent = result.count;
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            } catch (error) {
                console.error('Error updating favorites badge:', error);
            }
        }

        // Expose to global scope for other pages to call
        window.updateFavoritesBadge = updateFavoritesBadge;
        
        // ================== ANIMATED BACKGROUND ==================
        function createHomeParticles() {
            const animatedBg = document.getElementById('main-animated-bg');
            if (!animatedBg) return;
            
            const particleCount = 15;
            
            for (let i = 0; i < particleCount; i++) {
                const particle = document.createElement('div');
                particle.className = 'home-particle ' + (Math.random() > 0.5 ? 'light' : 'dark');
                
                // Random size
                const size = Math.random() * 50 + 30;
                particle.style.width = size + 'px';
                particle.style.height = size + 'px';
                
                // Random position
                particle.style.left = Math.random() * 100 + '%';
                particle.style.top = Math.random() * 100 + '%';
                
                // Animation
                const duration = Math.random() * 20 + 20;
                particle.style.animation = `floatHome ${duration}s ease-in-out infinite`;
                particle.style.animationDelay = Math.random() * 5 + 's';
                
                animatedBg.appendChild(particle);
            }
        }
        
        // Initialize on page load
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', createHomeParticles);
        } else {
            createHomeParticles();
        }
    </script>
    <script src="~/js/chatbox.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
