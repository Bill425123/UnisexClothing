                        </li>
                    </ul>
                </div>
            </div>

            <!-- Bottom Bar -->
            <div class="row mt-4 pt-4 border-top border-secondary">
                <div class="col-lg-6 text-center text-lg-start mb-3 mb-lg-0">
                    <small class="text-white-50">
                        &copy; 2025 UniStyle. All rights reserved. | 
                        <a href="#" class="text-white-50 text-decoration-none">Điều khoản</a> | 
                        <a href="#" class="text-white-50 text-decoration-none">Bảo mật</a>
                    </small>
                </div>
                <div class="col-lg-6 text-center text-lg-end">
                    <div class="d-inline-flex align-items-center gap-3">
                        <span class="bg-white rounded px-3 py-2" style="height: 35px; display: inline-flex; align-items: center;">
                            <i class="fas fa-shield-alt text-success me-1"></i>
                            <small class="text-dark fw-bold">Đã đăng ký</small>
                        </span>
                        <span class="bg-white rounded px-3 py-2" style="height: 35px; display: inline-flex; align-items: center;">
                            <i class="fas fa-lock text-primary me-1"></i>
                            <small class="text-dark fw-bold">SSL</small>
                        </span>
                        <span class="bg-white rounded px-3 py-2" style="height: 35px; display: inline-flex; align-items: center;">
                            <i class="fab fa-cc-visa text-primary me-1" style="font-size: 1.5rem;"></i>
