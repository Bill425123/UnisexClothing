@model UnisexClothes.ViewModels.CommentManagementViewModel

@{
    ViewData["Title"] = "Quản lý bình luận";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var totalComments = Model?.TotalComments ?? 0;
    var totalApproved = Model?.TotalApproved ?? 0;
    var totalPending = Model?.TotalPending ?? 0;
}

<div class="comments-dashboard container-fluid px-4">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-1">Quản lý bình luận</h1>
            <p class="text-muted mb-0">Theo dõi phản hồi khách hàng theo từng sản phẩm và xử lý nhanh chóng.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end comment-filters">
                <div class="col-md-4">
                    <label class="form-label text-muted mb-1">Tên sản phẩm</label>
                    <div class="input-icon">
                        <i class="fas fa-search"></i>
                        <input type="text" name="searchProduct" class="form-control" placeholder="Nhập tên sản phẩm..."
                               value="@Model?.SearchProduct" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label text-muted mb-1">Danh mục</label>
                    <select name="categoryId" class="form-select">
                        <option value="">Tất cả</option>
                        @if (Model?.Categories != null)
                        {
                            foreach (var category in Model.Categories)
                            {
                                <option value="@category.CategoryId" selected="@(Model.CategoryId == category.CategoryId)">
                                    @category.CategoryName
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-filter">
                        <i class="fas fa-filter me-2"></i> Lọc
                    </button>
                </div>
                <div class="col-md-2 d-grid">
                    <a href="@Url.Action("Index", "Comments")" class="btn btn-reset">
                        <i class="fas fa-undo me-2"></i> Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-4">
            <div class="stat-card shadow-sm">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="fas fa-comments"></i>
                </div>
                <div>
                    <p class="text-muted mb-1">Tổng bình luận</p>
                    <h3 class="fw-bold mb-0">@totalComments</h3>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="stat-card shadow-sm">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div>
                    <p class="text-muted mb-1">Đã duyệt</p>
                    <h3 class="fw-bold mb-0">@totalApproved</h3>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="stat-card shadow-sm">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="fas fa-clock"></i>
                </div>
                <div>
                    <p class="text-muted mb-1">Chờ duyệt</p>
                    <h3 class="fw-bold mb-0">@totalPending</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3">
                <div>
                    <h5 class="fw-semibold mb-1">Danh sách sản phẩm có bình luận</h5>
                    <span class="text-muted small">Cập nhật @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>

            @if (Model?.Products != null && Model.Products.Any())
            {
                <div class="table-responsive">
                    <table class="table comment-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Hình ảnh</th>
                                <th>Sản phẩm</th>
                                <th>Danh mục</th>
                                <th class="text-center">Tổng BL</th>
                                <th class="text-center">Đã duyệt</th>
                                <th class="text-center">Chờ duyệt</th>
                                <th class="text-center">Đánh giá TB</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model.Products)
                            {
                                <tr class="align-middle">
                                    <td>
                                        <div class="product-thumb">
                                            <img src="@Url.Content(string.IsNullOrWhiteSpace(product.ThumbnailUrl) ? "~/images/LogovsBrandingUniSex/logo.png" : product.ThumbnailUrl)"
                                                 alt="@product.ProductName" />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-semibold">@product.ProductName</div>
                                        <span class="text-muted small">#@product.ProductId</span>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary px-3 py-2">
                                            <i class="fas fa-layer-group me-1"></i>@product.CategoryName
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="stat-chip bg-primary bg-opacity-10 text-primary">@product.TotalComments</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="stat-chip bg-success bg-opacity-10 text-success">@product.ApprovedComments</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="stat-chip bg-warning bg-opacity-10 text-warning">@product.PendingComments</span>
                                    </td>
                                    <td class="text-center">
                                        @if (product.AverageRating.HasValue)
                                        {
                                            <span class="rating-chip">
                                                @product.AverageRating.Value.ToString("0.0")
                                                <i class="fas fa-star ms-1"></i>
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a class="btn btn-outline-dark btn-sm rounded-pill px-4"
                                           href="@Url.Action("Details", "Comments", new { productId = product.ProductId })">
                                            <i class="fas fa-eye me-1"></i> Xem bình luận
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model?.TotalPages > 1)
                {
                    <div class="d-flex justify-content-center mt-4">
                        <div class="comment-pagination d-flex align-items-center gap-2">
                            @{
                                var prevPage = Model.CurrentPage - 1;
                                var nextPage = Model.CurrentPage + 1;
                            }
                            <a class="page-btn @(Model.CurrentPage == 1 ? "disabled" : "")"
                               href="@(Model.CurrentPage == 1 ? "#" : Url.Action("Index", new { page = prevPage, searchProduct = Model.SearchProduct, categoryId = Model.CategoryId }))">
                                Trước
                            </a>
                            @for (var i = 1; i <= Model.TotalPages; i++)
                            {
                                <a class="page-btn @(Model.CurrentPage == i ? "active" : "")"
                                   href="@Url.Action("Index", new { page = i, searchProduct = Model.SearchProduct, categoryId = Model.CategoryId })">
                                    @i
                                </a>
                            }
                            <a class="page-btn @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")"
                               href="@(Model.CurrentPage == Model.TotalPages ? "#" : Url.Action("Index", new { page = nextPage, searchProduct = Model.SearchProduct, categoryId = Model.CategoryId }))">
                                Sau
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state text-center py-5">
                    <img src="@Url.Content("~/images/LogovsBrandingUniSex/logo.png")" alt="Empty" class="empty-state__image mb-3" />
                    <h5>Chưa có bình luận nào</h5>
                    <p class="text-muted mb-0">Hãy thử thay đổi bộ lọc hoặc quay lại sau khi có bình luận mới.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .comments-dashboard .card {
        border-radius: 18px;
    }

    .comment-filters .input-icon {
        position: relative;
    }

    .comment-filters .input-icon i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #a1a5b7;
    }

    .comment-filters .input-icon input {
        padding-left: 40px;
    }

    .btn-icon {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.2);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
    }

    .btn-gradient {
        background: linear-gradient(135deg, #7d8ffe, #5b6bff);
        border: none;
        color: #fff;
        padding: 12px 24px;
        border-radius: 16px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .btn-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 15px 30px rgba(93, 108, 255, 0.35);
        color: #fff;
    }

    .btn-filter {
        background: linear-gradient(120deg, #6c63ff, #8b7bff);
        color: #fff;
        border: none;
        border-radius: 14px;
        font-weight: 600;
        padding: 12px 0;
        transition: all 0.2s ease;
    }

    .btn-filter:hover {
        box-shadow: 0 10px 25px rgba(108, 99, 255, 0.35);
        color: #fff;
    }

    .btn-reset {
        border-radius: 14px;
        font-weight: 600;
        padding: 12px 0;
        border: 1px solid #e2e8f0;
        color: #5a5f7d;
        transition: all 0.2s ease;
        background: #fff;
    }

    .btn-reset:hover {
        border-color: #7d8ffe;
        color: #7d8ffe;
        box-shadow: 0 8px 20px rgba(125, 143, 254, 0.2);
    }

    .stat-card {
        background: #fff;
        border-radius: 18px;
        padding: 18px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
    }

    .comment-table thead th {
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        color: #8f9bb3;
        border-bottom: none;
        background: #f8f9fb;
        padding: 16px;
    }

    .comment-table tbody tr {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .comment-table tbody tr:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
    }

    .comment-table td {
        padding: 18px 16px;
        vertical-align: middle;
    }

    .product-thumb {
        width: 70px;
        height: 70px;
        border-radius: 16px;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .product-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .stat-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 50px;
        height: 36px;
        border-radius: 999px;
        font-weight: 600;
    }

    .rating-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #0d6efd;
        color: #fff;
        border-radius: 999px;
        padding: 6px 14px;
        font-weight: 600;
        box-shadow: 0 8px 20px rgba(13, 110, 253, 0.25);
    }

    .empty-state__image {
        width: 90px;
        opacity: 0.5;
    }

    .comment-pagination .page-btn {
        padding: 8px 18px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        color: #5a5f7d;
        font-weight: 600;
        transition: all 0.2s ease;
        text-decoration: none;
        background: #fff;
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.05);
    }

    .comment-pagination .page-btn:hover:not(.active):not(.disabled) {
        border-color: #7d8ffe;
        color: #7d8ffe;
    }

    .comment-pagination .page-btn.active {
        background: #7d8ffe;
        border-color: #7d8ffe;
        color: #fff;
        box-shadow: 0 10px 20px rgba(125, 143, 254, 0.3);
    }

    .comment-pagination .page-btn.disabled {
        opacity: 0.5;
        pointer-events: none;
    }
</style>
